{
  "name": "ethara-inventory",
  "private": true,
  "description": "Inventory & Order Management — Docker + FastAPI + React + MongoDB",
  "scripts": {
    "dev:api": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:web": "cd frontend && npm run dev",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "seed": "cd backend && python seed.py"
  }
}
